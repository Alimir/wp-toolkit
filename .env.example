# Copy this file to .env in your WordPress plugin project.

# Production deploy (wp-toolkit product)
DEPLOY_PROD_HOST=your-user@your-host.example
DEPLOY_PROD_PORT=22
DEPLOY_PROD_DEST=/home/your-user/www/wp-content/plugins/your-plugin/

# WordPress.org SVN (wp-toolkit release)
WP_SVN_USER=your-wordpress-org-username
WP_SVN_PASSWORD=your-wordpress-org-application-password
WP_SVN_URL=https://plugins.svn.wordpress.org/your-plugin

# Optional: preview release without publishing
# WP_RELEASE_DRY_RUN=1

# Optional: skip the interactive confirmation prompt
# WP_RELEASE_YES=1

# Optional: custom SVN commit message
# WP_RELEASE_MESSAGE=Updating to 1.0.0
